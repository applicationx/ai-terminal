{
  "name": "ai-terminal",
  "version": "1.0.0",
  "description": "",
  "main": "dist-electron/main.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -k \"vite\" \"npm run electron:dev\"",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "build:win": "npm run build && electron-builder --win",
    "electron:dev": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && electron .",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.applicationx.aiterminal",
    "productName": "AI Terminal",
    "directories": {
      "output": "dist-build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/applicationx/ai-terminal.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/applicationx/ai-terminal/issues"
  },
  "homepage": "https://github.com/applicationx/ai-terminal#readme",
  "dependencies": {
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
